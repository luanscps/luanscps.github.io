---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<Layout title="Luan - Desenvolvedor Python & DevOps">
  <main>
    <div class="container">
      <!-- Hero Section -->
      <section class="hero">
        <div class="profile-header">
          <img 
            src="https://avatars.githubusercontent.com/u/13770810?v=4" 
            alt="Luan" 
            class="profile-image"
          />
          <div class="profile-info">
            <h1>Luan</h1>
            <p class="subtitle">Desenvolvedor Python | Docker | IA</p>
            <p class="location">📍 Brasil</p>
            <SocialLinks />
          </div>
        </div>
      </section>

      <!-- About Section -->
      <section class="about">
        <Card>
          <h2>👨‍💻 Sobre Mim</h2>
          <p>
            Desenvolvedor apaixonado por automação, containerização e inteligência artificial.
            Experiência com Python, Docker, sistemas de trading e soluções ERP com Odoo.
          </p>
          <div class="stats">
            <div class="stat">
              <span class="stat-number">10</span>
              <span class="stat-label">Repositórios Públicos</span>
            </div>
            <div class="stat">
              <span class="stat-number">2015</span>
              <span class="stat-label">No GitHub desde</span>
            </div>
          </div>
        </Card>
      </section>

      <!-- Skills Section -->
      <section class="skills">
        <h2>🛠️ Habilidades</h2>
        <div class="skills-grid">
          <div class="skill-category">
            <h3>Linguagens</h3>
            <div class="skill-tags">
              <span class="tag">Python</span>
              <span class="tag">Shell</span>
              <span class="tag">PHP</span>
            </div>
          </div>
          <div class="skill-category">
            <h3>DevOps & Infra</h3>
            <div class="skill-tags">
              <span class="tag">Docker</span>
              <span class="tag">Portainer</span>
              <span class="tag">CasaOS</span>
              <span class="tag">Prometheus</span>
              <span class="tag">Grafana</span>
            </div>
          </div>
          <div class="skill-category">
            <h3>IA & Machine Learning</h3>
            <div class="skill-tags">
              <span class="tag">Ollama</span>
              <span class="tag">LLM</span>
              <span class="tag">SmolLM2</span>
              <span class="tag">Mistral</span>
              <span class="tag">DeepSeek</span>
            </div>
          </div>
          <div class="skill-category">
            <h3>Sistemas & ERP</h3>
            <div class="skill-tags">
              <span class="tag">Odoo</span>
              <span class="tag">NFe Brasil</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Projects Section -->
      <section class="projects">
        <h2>🚀 Projetos em Destaque</h2>
        <div class="projects-grid">
          <ProjectCard
            title="Trading System Agent B3"
            description="Sistema autônomo 24/7 de análise financeira com 5 modelos IA em cascata (SmolLM2, Mistral, DeepSeek-R1, Qwen2.5-Coder, Gemma3)"
            url="https://github.com/luanscps/trading-system-agent-b3"
            language="Python"
            topics={['AI', 'Trading', 'Ollama', 'B3']}
          />
          
          <ProjectCard
            title="OpenClaw BR"
            description="Assistente de IA Pessoal com instalação otimizada para CasaOS + Portainer + macvlan-dhcp"
            url="https://github.com/luanscps/openclaw-br"
            language="Shell"
            topics={['AI', 'Docker', 'CasaOS']}
          />
          
          <ProjectCard
            title="Odoo Brasil Docker"
            description="Odoo 18.0 localização brasileira com NFe - Instalação via Docker com Portainer e macvlan-dhcp"
            url="https://github.com/luanscps/odoobr"
            language="Shell"
            topics={['Odoo', 'ERP', 'Docker', 'NFe']}
          />
          
          <ProjectCard
            title="Monitoring Stack"
            description="Prometheus + Grafana monitoring stack para CasaOS com suporte macvlan"
            url="https://github.com/luanscps/monitoring"
            language="Shell"
            topics={['Monitoring', 'Prometheus', 'Grafana']}
          />
        </div>
      </section>

      <!-- Contact Section -->
      <section class="contact">
        <Card>
          <h2>📧 Entre em Contato</h2>
          <p>Interessado em colaborar ou discutir projetos? Fique à vontade para entrar em contato!</p>
          <a href="mailto:luanscps@gmail.com" class="btn-primary">Enviar E-mail</a>
        </Card>
      </section>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    margin-bottom: 4rem;
  }

  .profile-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .profile-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    border: 4px solid var(--accent);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .profile-info h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(45deg, var(--accent), var(--accent-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .location {
    color: var(--text-secondary);
  }

  .about {
    margin-bottom: 4rem;
  }

  .stats {
    display: flex;
    gap: 3rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: bold;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .skills {
    margin-bottom: 4rem;
  }

  .skills h2 {
    margin-bottom: 2rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .skill-category h3 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    border: 1px solid rgba(var(--accent-rgb), 0.3);
  }

  .projects {
    margin-bottom: 4rem;
  }

  .projects h2 {
    margin-bottom: 2rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .contact {
    margin-bottom: 4rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--accent);
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
    margin-top: 1rem;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(var(--accent-rgb), 0.3);
  }

  @media (max-width: 768px) {
    .profile-header {
      flex-direction: column;
      text-align: center;
    }

    .profile-info h1 {
      font-size: 2rem;
    }
  }
</style>
